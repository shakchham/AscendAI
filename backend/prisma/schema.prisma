generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  consultancy_admin
  teacher
  super_admin
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum TaskStatus {
  pending
  completed
}

model User {
  id              String      @id
  email           String?     @unique
  phone           String?     @unique
  role            UserRole    @default(student)
  consultancyId   String?     @map("consultancy_id")
  parentId        String?     @map("parent_id")
  termsAcceptedAt DateTime?   @map("terms_accepted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  essays          Essay[]
  payments        Payment[]
  fromMessages    Message[]    @relation("from_messages")
  toMessages      Message[]    @relation("to_messages")

  @@map("users")
}

model Consultancy {
  id               String   @id @default(uuid())
  name             String
  logoUrl          String?  @map("logo_url")
  primaryColor     String?  @map("primary_color")
  customDomain     String?  @map("custom_domain")
  subscriptionPlan String?  @map("subscription_plan")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("consultancies")
}

model Student {
  userId       String  @id @map("user_id")
  targetScore  Float?  @map("target_score")
  currentScore Float?  @default(0) @map("current_score")
  batchId      String? @map("batch_id")

  @@map("students")
}

model Batch {
  id            String @id @default(uuid())
  consultancyId String @map("consultancy_id")
  branch        String
  name          String

  @@map("batches")
}

model MockTest {
  id        String  @id @default(uuid())
  type      String
  questions Json
  answers   Json
  timeLimit Int     @map("time_limit")

  @@map("mock_tests")
}

model TestAttempt {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  testId      String   @map("test_id")
  score       Float
  answers     Json
  completedAt DateTime @default(now()) @map("completed_at")

  @@map("test_attempts")
}

model Essay {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  student     User     @relation(fields: [studentId], references: [id])
  content     String
  aiFeedback  String   @map("ai_feedback")
  submittedAt DateTime @default(now()) @map("submitted_at")

  @@map("essays")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  amount        Float
  status        PaymentStatus @default(pending)
  paymentMethod String        @map("payment_method")
  transactionId String?       @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("payments")
}

model Message {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  fromUser   User     @relation("from_messages", fields: [fromUserId], references: [id])
  toUserId   String   @map("to_user_id")
  toUser     User     @relation("to_messages", fields: [toUserId], references: [id])
  content    String   // encrypted payload
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Certificate {
  id               String   @id @default(uuid())
  studentId        String   @map("student_id")
  issuedAt         DateTime @default(now()) @map("issued_at")
  verificationCode String   @unique @map("verification_code")

  @@map("certificates")
}

model CounsellorTask {
  id           String     @id @default(uuid())
  consultancyId String    @map("consultancy_id")
  counsellorId String     @map("counsellor_id")
  studentId    String     @map("student_id")
  title        String
  status       TaskStatus @default(pending)
  dueAt        DateTime?  @map("due_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("counsellor_tasks")
}

model TestSchedule {
  id           String   @id @default(uuid())
  consultancyId String  @map("consultancy_id")
  batchId      String   @map("batch_id")
  testType     String   @map("test_type")
  scheduledAt  DateTime @map("scheduled_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("test_schedules")
}

model WeeklyReport {
  id            String   @id @default(uuid())
  consultancyId String   @map("consultancy_id")
  studentId     String   @map("student_id")
  pdfUrl        String?  @map("pdf_url")
  sentEmail     Boolean  @default(false) @map("sent_email")
  generatedAt   DateTime @default(now()) @map("generated_at")

  @@map("weekly_reports")
}

model FeeRecord {
  id            String        @id @default(uuid())
  consultancyId String        @map("consultancy_id")
  studentId     String        @map("student_id")
  amount        Float
  dueDate       DateTime      @map("due_date")
  status        PaymentStatus @default(pending)
  reminderSent  Boolean       @default(false) @map("reminder_sent")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("fee_records")
}

model ClassBooking {
  id            String   @id @default(uuid())
  consultancyId String   @map("consultancy_id")
  studentId     String   @map("student_id")
  slotAt        DateTime @map("slot_at")
  status        String   @default("booked")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("class_bookings")
}
