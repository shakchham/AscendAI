generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  consultancy_admin
  teacher
  super_admin
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum TaskStatus {
  pending
  completed
}

enum SubscriptionPlan {
  monthly_1500
  yearly_15000
  consultancy_per_student_1000
}

enum DeletionStatus {
  pending
  completed
  rejected
}

enum WebhookProvider {
  esewa
  khalti
  stripe
}

model User {
  id              String      @id
  email           String?     @unique
  phone           String?     @unique
  role            UserRole    @default(student)
  consultancyId   String?     @map("consultancy_id")
  parentId        String?     @map("parent_id")
  termsAcceptedAt DateTime?   @map("terms_accepted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  essays          Essay[]
  payments        Payment[]
  fromMessages    Message[]    @relation("from_messages")
  toMessages      Message[]    @relation("to_messages")
  subscriptions   Subscription[]
  apiKeys         ApiKey[]
  auditLogs       AuditLog[]
  deletionRequests DeletionRequest[]
  speakingAttempts SpeakingAttempt[]
  adaptiveAttempts AdaptiveAttempt[]
  proctorEvents   ProctorEvent[]

  @@map("users")
}

model Consultancy {
  id               String   @id @default(uuid())
  name             String
  logoUrl          String?  @map("logo_url")
  primaryColor     String?  @map("primary_color")
  customDomain     String?  @map("custom_domain")
  subscriptionPlan String?  @map("subscription_plan")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("consultancies")
}

model Student {
  userId       String  @id @map("user_id")
  targetScore  Float?  @map("target_score")
  currentScore Float?  @default(0) @map("current_score")
  batchId      String? @map("batch_id")

  @@map("students")
}

model Batch {
  id            String @id @default(uuid())
  consultancyId String @map("consultancy_id")
  branch        String
  name          String

  @@map("batches")
}

model MockTest {
  id        String  @id @default(uuid())
  type      String
  questions Json
  answers   Json
  timeLimit Int     @map("time_limit")

  @@map("mock_tests")
}

model TestAttempt {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  testId      String   @map("test_id")
  score       Float
  answers     Json
  completedAt DateTime @default(now()) @map("completed_at")

  @@map("test_attempts")
}

model Essay {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  student     User     @relation(fields: [studentId], references: [id])
  content     String
  aiFeedback  String   @map("ai_feedback")
  submittedAt DateTime @default(now()) @map("submitted_at")

  @@map("essays")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  amount        Float
  status        PaymentStatus @default(pending)
  paymentMethod String        @map("payment_method")
  transactionId String?       @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("payments")
}

model Message {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  fromUser   User     @relation("from_messages", fields: [fromUserId], references: [id])
  toUserId   String   @map("to_user_id")
  toUser     User     @relation("to_messages", fields: [toUserId], references: [id])
  content    String   // encrypted payload
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Certificate {
  id               String   @id @default(uuid())
  studentId        String   @map("student_id")
  issuedAt         DateTime @default(now()) @map("issued_at")
  verificationCode String   @unique @map("verification_code")

  @@map("certificates")
}

model CounsellorTask {
  id           String     @id @default(uuid())
  consultancyId String    @map("consultancy_id")
  counsellorId String     @map("counsellor_id")
  studentId    String     @map("student_id")
  title        String
  status       TaskStatus @default(pending)
  dueAt        DateTime?  @map("due_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("counsellor_tasks")
}

model TestSchedule {
  id           String   @id @default(uuid())
  consultancyId String  @map("consultancy_id")
  batchId      String   @map("batch_id")
  testType     String   @map("test_type")
  scheduledAt  DateTime @map("scheduled_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("test_schedules")
}

model WeeklyReport {
  id            String   @id @default(uuid())
  consultancyId String   @map("consultancy_id")
  studentId     String   @map("student_id")
  pdfUrl        String?  @map("pdf_url")
  sentEmail     Boolean  @default(false) @map("sent_email")
  generatedAt   DateTime @default(now()) @map("generated_at")

  @@map("weekly_reports")
}

model FeeRecord {
  id            String        @id @default(uuid())
  consultancyId String        @map("consultancy_id")
  studentId     String        @map("student_id")
  amount        Float
  dueDate       DateTime      @map("due_date")
  status        PaymentStatus @default(pending)
  reminderSent  Boolean       @default(false) @map("reminder_sent")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("fee_records")
}

model ClassBooking {
  id            String   @id @default(uuid())
  consultancyId String   @map("consultancy_id")
  studentId     String   @map("student_id")
  slotAt        DateTime @map("slot_at")
  status        String   @default("booked")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("class_bookings")
}

model Subscription {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  plan      SubscriptionPlan
  amount    Float
  status    PaymentStatus    @default(pending)
  startAt   DateTime         @default(now()) @map("start_at")
  endAt     DateTime?        @map("end_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("subscriptions")
}

model PaymentWebhookEvent {
  id            String          @id @default(uuid())
  provider      WebhookProvider
  payload       Json
  processed     Boolean         @default(false)
  receivedAt    DateTime        @default(now()) @map("received_at")

  @@map("payment_webhook_events")
}

model QuestionBank {
  id            String   @id @default(uuid())
  consultancyId String   @map("consultancy_id")
  examType      String   @map("exam_type")
  title         String
  questions     Json
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("question_banks")
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  keyHash    String   @map("key_hash")
  label      String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model DeletionRequest {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  user         User           @relation(fields: [userId], references: [id])
  status       DeletionStatus @default(pending)
  requestedAt  DateTime       @default(now()) @map("requested_at")
  processBy    DateTime?      @map("process_by")
  completedAt  DateTime?      @map("completed_at")

  @@map("deletion_requests")
}

model AdaptiveAttempt {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id])
  examType           String   @map("exam_type")
  currentDifficulty  Int      @default(2) @map("current_difficulty")
  questionIndex      Int      @default(0) @map("question_index")
  score              Float    @default(0)
  state              Json?
  completed          Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("adaptive_attempts")
}

model SpeakingAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id])
  transcript     String?
  aiFeedback     String   @map("ai_feedback")
  audioRef       String?  @map("audio_ref")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("speaking_attempts")
}

model ProctorEvent {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  attemptId  String?  @map("attempt_id")
  eventType  String   @map("event_type")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("proctor_events")
}
